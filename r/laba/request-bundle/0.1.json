{
    "manifests": {
        "laba/request-bundle": {
            "ref": "main",
            "manifest": {
                "bundles": {
                    "Laba\\RequestBundle\\RequestBundle": [
                        "all"
                    ]
                },
                "copy-from-recipe": {
                    "config/": "%CONFIG_DIR%/"
                }
            },
            "files": {
                "config/packages/laba_request.yaml": {
                    "contents": [
                        "laba_request:",
                        "    api_request_log:",
                        "        entity: App\\Entity\\ApiRequestLog",
                        "        excluded_paths:",
                        "            - '^(?!/api)'               # все що не /api/*",
                        "            - '^/api/api_request_logs'  # сам endpoint логів",
                        "        keep_last_per_path: true        # при retention зберігати останній запис на кожен path"
                    ],
                    "executable": false
                }
            }
        }
    }
}